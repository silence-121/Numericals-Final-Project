# ─────────────────────────────────────────────
#  MATH HELPERS
# ─────────────────────────────────────────────
def safe_eval(x_val: float, eq: str) -> float:
    eq = eq.replace("^", "**")
    allowed = {k: getattr(math, k) for k in dir(math) if not k.startswith("_")}
    allowed["x"] = x_val
    try:
        result = eval(eq, {"__builtins__": {}}, allowed)
        if not math.isfinite(result):
            raise ValueError("Result is inf or NaN")
        return float(result)
    except Exception as e:
        raise ValueError(f"Bad equation: {e}")
def num_deriv(x_val, eq):
    h = 1e-5
    return (safe_eval(x_val + h, eq) - safe_eval(x_val - h, eq)) / (2 * h)
def stop_crit(ea, fval, tol=0.001):
    return abs(fval) < tol or (ea != 0 and ea < tol)
def fmt(v):
    try:
        return f"{float(v):.4f}"
    except Exception:
        return str(v)
