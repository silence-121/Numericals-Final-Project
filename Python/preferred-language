def make_label(parent, text, fg=TXT, bg=PNL, font_size=10, bold=False, **kw):
    return tk.Label(parent, text=text, fg=fg, bg=bg,
                    font=("Segoe UI", font_size, "bold" if bold else "normal"), **kw)

def styled_button(parent, text, command, bg=BTN_CLR, fg=TXT, width=18, hover_bg=None):
    hbg = hover_bg or ACC_R
    b = tk.Button(parent, text=text, command=command,
                  bg=bg, fg=fg, activebackground=hbg, activeforeground="#fff",
                  font=("Segoe UI", 10, "bold"), relief="flat",
                  cursor="hand2", width=width, borderwidth=0)
    b.bind("<Enter>", lambda e: b.config(bg=hbg))
    b.bind("<Leave>", lambda e: b.config(bg=bg))
    return b


