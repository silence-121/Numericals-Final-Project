# ─────────────────────────────────────────────
class BgImageManager:
    def __init__(self):
        self._root  = None
        self._label = None
        self._photo = None
        self._path  = None

    def attach(self, root, notebook):
        self._root = root; self._notebook = notebook
        self._label = tk.Label(root, bg=BG, bd=0, highlightthickness=0)
        self._label.place(x=0, y=0, relwidth=1, relheight=1)
        notebook.lift()
        root.bind("<Configure>", self._on_resize)

    def load(self, path):
        if not PIL_AVAILABLE:
            messagebox.showwarning("Pillow missing",
                "Install Pillow:\n  pip install pillow"); return
        self._path = path; self._redraw()

    def _redraw(self):
        if not self._path or not self._label: return
        self._root.update_idletasks()
        w = self._root.winfo_width(); h = self._root.winfo_height()
        if w < 10 or h < 10: return
        try:
            img = Image.open(self._path).convert("RGBA")
            img = img.resize((w, h), Image.LANCZOS)
            overlay = Image.new("RGBA", (w, h), (245, 247, 250, 180))
            img = Image.alpha_composite(img, overlay).convert("RGB")
            self._photo = ImageTk.PhotoImage(img)
            self._label.config(image=self._photo)
            self._notebook.lift()
        except Exception as ex:
            messagebox.showerror("Image Error", str(ex))

    def _on_resize(self, event):
        if self._path:
            if hasattr(self, "_resize_job") and self._resize_job:
                self._root.after_cancel(self._resize_job)
            self._resize_job = self._root.after(80, self._redraw)

    def clear(self):
        self._path = None; self._photo = None
        if self._label: self._label.config(image="")


