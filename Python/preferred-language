    def _need_square(self, M, name):
        if M.shape[0] != M.shape[1]:
            raise ValueError(f"{name} must be square.")

    def do_matrix(self, op):
        try:
            A = parse_matrix(self.eA.get())
            B = parse_matrix(self.eB.get())

            out_text = ""

            # ── Topic 2 ────────────────────────────────────
            if op == "Add A+B":
                if A.shape != B.shape: raise ValueError("Same dimensions required.")
                out_text = f"A + B =\n{format_matrix(A + B)}"
            elif op == "Subtract A-B":
                if A.shape != B.shape: raise ValueError("Same dimensions required.")
                out_text = f"A - B =\n{format_matrix(A - B)}"
            elif op == "Multiply A*B":
                if A.shape[1] != B.shape[0]:
                    raise ValueError("Cols of A must equal rows of B.")
                out_text = f"A x B =\n{format_matrix(A @ B)}"
            elif op == "Multiply B*A":
                if B.shape[1] != A.shape[0]:
                    raise ValueError("Cols of B must equal rows of A.")
                out_text = f"B x A =\n{format_matrix(B @ A)}"
            elif op == "Transpose A":
                out_text = f"A^T =\n{format_matrix(A.T)}"
            elif op == "Transpose B":
                out_text = f"B^T =\n{format_matrix(B.T)}"
            elif op == "A^2":
                self._need_square(A, "A")
                out_text = f"A^2 =\n{format_matrix(A @ A)}"
            elif op == "B^2":
                self._need_square(B, "B")
                out_text = f"B^2 =\n{format_matrix(B @ B)}"
            elif op == "A^2 + B^2":
                self._need_square(A, "A"); self._need_square(B, "B")
                if A.shape != B.shape: raise ValueError("Same size required.")
                out_text = f"A^2 + B^2 =\n{format_matrix(A@A + B@B)}"

            # ── Topic 3 — Determinants ─────────────────────
            elif op in ("Det A (Cofactor)", "Det B (Cofactor)"):
                M = A if "A" in op else B
                name = "A" if "A" in op else "B"
                self._need_square(M, name)
                if M.shape[0] == 1:
                    val = float(M[0,0])
                    out_text = f"|{name}| = {val:.4f}"
                elif M.shape[0] == 2:
                    val = float(M[0,0]*M[1,1] - M[0,1]*M[1,0])
                    out_text = (f"|{name}| (2x2 formula: ad - bc)\n"
                                f"  = ({M[0,0]:.2f})({M[1,1]:.2f}) - ({M[0,1]:.2f})({M[1,0]:.2f})\n"
                                f"  = {val:.4f}")
                else:
                    val, steps = det_cofactor_expansion(M)
                    out_text = (f"|{name}| via Cofactor Expansion (Laplace, 1st row):\n"
                                + "\n".join(steps)
                                + f"\n  {'─'*30}\n  |{name}| = {val:.4f}")

            # ── Topic 4 — Cofactor / Adjoint / Inverse ─────
            elif op in ("Cofactor Matrix A", "Cofactor Matrix B"):
                M = A if "A" in op else B
                name = "A" if "A" in op else "B"
                self._need_square(M, name)
                C = cofactor_matrix(M)
                out_text = (f"Cofactor matrix of {name} "
                            f"(Cij = (-1)^(i+j) * Mij):\n{format_matrix(C)}")

            elif op in ("Adjoint A", "Adjoint B"):
                M = A if "A" in op else B
                name = "A" if "A" in op else "B"
                self._need_square(M, name)
                adj = adjoint_matrix(M)
                out_text = (f"adj({name}) = transpose of cofactor matrix:\n"
                            f"{format_matrix(adj)}")

            elif op in ("Inverse A (Adjoint)", "Inverse B (Adjoint)"):
                M = A if "A" in op else B
                name = "A" if "A" in op else "B"
                self._need_square(M, name)
                d = np.linalg.det(M)
                if abs(d) < 1e-12:
                    raise ValueError(f"{name} is singular (|{name}| = 0). Inverse does not exist.")
                adj = adjoint_matrix(M)
                inv = adj / d
                out_text = (f"|{name}| = {d:.4f}\n\n"
                            f"adj({name}) =\n{format_matrix(adj)}\n\n"
                            f"{name}^-1 = adj({name}) / |{name}| =\n{format_matrix(inv)}")

            else:
                raise ValueError("Unknown operation.")

            self.write(f"Operation : {op}\n{'='*50}\n\n{out_text}\n")

        except Exception as ex:
            self.write(f"Error: {ex}")


