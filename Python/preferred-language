    def build_inputs(self):
        for w in self.input_frame.winfo_children(): w.destroy()
        self.input_widgets.clear()
        defs = {
            "Bisection":      [("XL","1"),("XU","2")],
            "False Position": [("XL","-0.5"),("XU","1")],
            "Secant":         [("Xi-1","1"),("Xi","2")],
            "Newton":         [("Xi","1")],
            "Incremental":    [("XL","0"),("Step","0.5")],
        }[self.method_var.get()]
        for label, default in defs:
            make_label(self.input_frame, label, fg=ACC_R, bg=PNL,
                       bold=True, font_size=9).pack(anchor="w", pady=(8,0))
            e = tk.Entry(self.input_frame, bg=ENTRY, fg=TXT, insertbackground=ACC_L,
                         font=("Segoe UI",12), relief="flat", width=32,
                         highlightthickness=1, highlightcolor=ACC_R,
                         highlightbackground=BORDER)
            e.insert(0, default); e.pack(ipady=5, pady=(2,0))
            self.input_widgets[label] = e

    def get_input(self, label): return float(self.input_widgets[label].get())

    def do_solve(self):
        eq = self.eq_var.get().strip()
        m  = self.method_var.get()
        try:
            try:
                tol = float(self.tol_var.get())
                if tol <= 0: raise ValueError
            except ValueError:
                messagebox.showerror("Input Error","Tolerance must be a positive number."); return
            try:
                max_iter = int(self.maxiter_var.get())
                if max_iter < 1: raise ValueError
            except ValueError:
                messagebox.showerror("Input Error","Max Iterations must be a positive integer."); return
            mode = self.stop_mode.get()
            eff_tol      = tol      if mode in ("tol","both")  else 1e-300
            eff_max_iter = max_iter if mode in ("iter","both") else 10_000
            if m == "Bisection":
                root,rows,cols = m_bisection(eq, self.get_input("XL"), self.get_input("XU"),
                                             tol=eff_tol, max_iter=eff_max_iter)
            elif m == "False Position":
                root,rows,cols = m_false_pos(eq, self.get_input("XL"), self.get_input("XU"),
                                             tol=eff_tol, max_iter=eff_max_iter)
            elif m == "Secant":
                root,rows,cols = m_secant(eq, self.get_input("Xi-1"), self.get_input("Xi"),
                                          tol=eff_tol, max_iter=eff_max_iter)
            elif m == "Newton":
                root,rows,cols = m_newton(eq, self.get_input("Xi"),
                                          tol=eff_tol, max_iter=eff_max_iter)
            elif m == "Incremental":
                root,rows,cols = m_incremental(eq, self.get_input("XL"), self.get_input("Step"),
                                               tol=eff_tol, max_iter=eff_max_iter)
            else:
                raise ValueError("Unknown method")
            self.populate_table(cols, rows)
            self._last_rows=rows; self._last_cols=cols; self._last_method=m
            n = len(rows)
            stopped_by = "tolerance" if n < eff_max_iter else "max iterations"
            self.result_var.set(
                f"Root = {root:.6f}  [{n} iter, stopped by {stopped_by}]"
                if root is not None else "No root found")
        except Exception as ex:
            messagebox.showerror("Error", str(ex))

    def populate_table(self, cols, rows):
        self.tree.delete(*self.tree.get_children())
        self.tree["columns"] = cols
        for c in cols:
            self.tree.heading(c, text=c)
            self.tree.column(c, width=max(80, len(c)*9), anchor="center")
        for i, row in enumerate(rows):
            tag = "even" if i%2==0 else "odd"
            self.tree.insert("","end", values=row, tags=(tag,))
        self.tree.tag_configure("even", background="#ffffff")
        self.tree.tag_configure("odd",  background="#f8f9fa")

    def do_clear(self):
        self.tree.delete(*self.tree.get_children())
        self.tree["columns"] = []
        self.result_var.set("Root = ---")
        self._last_rows=[]; self._last_cols=[]; self._last_method=""
        self.build_inputs()

    def do_plot(self):
        eq = self.eq_var.get().strip()
        rows = self._last_rows; method = self._last_method
        col_map = {"Bisection":2,"False Position":3,"Secant":3,"Newton":1,"Incremental":3}
        x_col = col_map.get(method, 1)
        pts = []
        for row in rows:
            try: pts.append((int(row[0]), float(row[x_col])))
            except: pass
        t = threading.Thread(
            target=do_plot,
            args=(eq, pts or None, method),
            daemon=True
        )
        t.start()


