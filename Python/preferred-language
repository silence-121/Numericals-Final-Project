#  MATRIX HELPERS
# ─────────────────────────────────────────────
def parse_matrix(text):
    rows = [r.strip() for r in text.strip().split(";") if r.strip()]
    arr = np.array([[float(v) for v in r.split()] for r in rows])
    if arr.ndim != 2:
        raise ValueError("Invalid matrix format.")
    return arr
def format_matrix(M):
    if np.isscalar(M) or (isinstance(M, np.ndarray) and M.ndim == 0):
        return f"  {float(M):.4f}"
    return "\n".join("  " + "   ".join(f"{v:12.4f}" for v in row)
                     for row in np.atleast_2d(M))
def minor(M, i, j):
    sub = np.delete(np.delete(M, i, axis=0), j, axis=1)
    return np.linalg.det(sub)
def cofactor_matrix(M):
    n = M.shape[0]
    C = np.zeros((n, n))
    for i in range(n):
        for j in range(n):
            C[i, j] = ((-1) ** (i + j)) * minor(M, i, j)
    return C
def adjoint_matrix(M):
    return cofactor_matrix(M).T
def det_cofactor_expansion(M):
    n = M.shape[0]
    if n == 1:
        return float(M[0, 0]), [f"  |M| = {float(M[0,0]):.4f}"]
    if n == 2:
        v = float(M[0,0]*M[1,1] - M[0,1]*M[1,0])
        return v, [f"  ad - bc = {M[0,0]:.2f}*{M[1,1]:.2f} - {M[0,1]:.2f}*{M[1,0]:.2f} = {v:.4f}"]
    total = 0.0
    steps = []
    for j in range(n):
        sign = (-1) ** j
        m_ij = minor(M, 0, j)
        term = sign * M[0, j] * m_ij
        total += term
        steps.append(f"  ({'+' if sign>0 else '-'}) {M[0,j]:.4f} x M[0,{j}] = {term:+.4f}")
    return total, steps
