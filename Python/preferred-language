#  ROOT-FINDING METHODS
# ─────────────────────────────────────────────
def m_bisection(eq, xl, xu, tol=0.001, max_iter=50):
    cols = ["Iter","XL","XR","XU","f(XL)","f(XR)","Ea(%)","f(XL)*f(XR)","Remark"]
    rows = []; xr_old = None
    for i in range(1, max_iter + 1):
        xr = (xl + xu) / 2
        fxl = safe_eval(xl, eq); fxr = safe_eval(xr, eq)
        ea = 0.0
        if xr_old is not None and xr != 0:
            ea = abs((xr - xr_old) / xr) * 100
        prod = fxl * fxr
        remark = "Left" if prod < 0 else "Right"
        rows.append([i, fmt(xl), fmt(xr), fmt(xu), fmt(fxl), fmt(fxr), fmt(ea), fmt(prod), remark])
        if stop_crit(ea, fxr, tol): break
        if prod < 0: xu = xr
        else: xl = xr
        xr_old = xr
    return float(rows[-1][2]), rows, cols
def m_false_pos(eq, xl, xu, tol=0.001, max_iter=50):
    cols = ["Iter","XL","XU","XR","Ea(%)","f(XL)","f(XU)","f(XR)","f(XL)*f(XR)","Remark"]
    rows = []; xr_old = None
    for i in range(1, max_iter + 1):
        fxl = safe_eval(xl, eq); fxu = safe_eval(xu, eq)
        if fxl - fxu == 0:
            raise ValueError("Division by zero (f(XL) = f(XU)).")
        xr = (xu * fxl - xl * fxu) / (fxl - fxu)
        fxr = safe_eval(xr, eq)
        ea = 0.0
        if xr_old is not None and xr != 0:
            ea = abs((xr - xr_old) / xr) * 100
        prod = fxl * fxr
        remark = "Left" if prod < 0 else ("Right" if prod > 0 else "Root")
        rows.append([i, fmt(xl), fmt(xu), fmt(xr), fmt(ea),
                     fmt(fxl), fmt(fxu), fmt(fxr), fmt(prod), remark])
        if stop_crit(ea, fxr, tol): break
        if prod < 0: xu = xr
        else: xl = xr
        xr_old = xr
    return float(rows[-1][3]), rows, cols
def m_secant(eq, x0, x1, tol=0.001, max_iter=50):
    cols = ["Iter","Xi-1","Xi","Xi+1","Ea(%)","f(Xi-1)","f(Xi)","f(Xi+1)"]
    rows = []
    for i in range(1, max_iter + 1):
        f0 = safe_eval(x0, eq); f1 = safe_eval(x1, eq)
        if f0 - f1 == 0:
            raise ValueError("Division by zero in Secant (f(Xi-1) = f(Xi)).")
        x2 = x1 - f1 * (x0 - x1) / (f0 - f1)
        f2 = safe_eval(x2, eq)
        ea = abs((x2 - x1) / x2) * 100 if x2 != 0 else 0.0
        rows.append([i, fmt(x0), fmt(x1), fmt(x2), fmt(ea), fmt(f0), fmt(f1), fmt(f2)])
        if stop_crit(ea, f2, tol): break
        x0, x1 = x1, x2
    return float(rows[-1][3]), rows, cols
def m_newton(eq, x0, tol=0.001, max_iter=50):
    cols = ["Iter","Xi","Ea(%)","f(Xi)","f'(Xi)","Xi+1"]
    rows = []
    for i in range(1, max_iter + 1):
        fx = safe_eval(x0, eq); dfx = num_deriv(x0, eq)
        if dfx == 0:
            raise ValueError("Division by zero (f'(x) = 0). Try a different initial guess.")
        x1 = x0 - fx / dfx
        ea = abs((x1 - x0) / x1) * 100 if x1 != 0 else 0.0
        rows.append([i, fmt(x0), fmt(ea), fmt(fx), fmt(dfx), fmt(x1)])
        if stop_crit(ea, fx, tol): break
        x0 = x1
    return float(rows[-1][5]), rows, cols
def m_incremental(eq, x0, step, tol=0.001, max_iter=50, refine_passes=4):
    cols = ["Iter","XL","DX","XU","f(XL)","f(XU)","f(XL)*f(XU)","Remark"]
    rows = []; root = None
    iter_no = 0
    current_step = step
    for _ in range(refine_passes + 1):
        sign_changed = False
        while iter_no < max_iter:
            iter_no += 1
            x1 = x0 + current_step
            f0 = safe_eval(x0, eq); f1 = safe_eval(x1, eq)
            prod = f0 * f1
            if abs(f1) < tol:
                rows.append([iter_no, fmt(x0), fmt(current_step), fmt(x1),
                             fmt(f0), fmt(f1), fmt(prod), "Root found"])
                return x1, rows, cols
            if prod < 0:
                rows.append([iter_no, fmt(x0), fmt(current_step), fmt(x1),
                             fmt(f0), fmt(f1), fmt(prod),
                             f"Sign change -> refine (dx = {current_step/10:.5f})"])
                current_step = current_step / 10
                sign_changed = True
                break
            else:
                rows.append([iter_no, fmt(x0), fmt(current_step), fmt(x1),
                             fmt(f0), fmt(f1), fmt(prod), "No root in interval"])
                x0 = x1
        if not sign_changed:
            break
    if rows:
        try:
            root = (float(rows[-1][1]) + float(rows[-1][3])) / 2
        except Exception:
            root = None
    return root, rows, cols
