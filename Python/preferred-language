def do_plot(eq, iter_points=None, method_name=""):
    try:
        import matplotlib
        try:
            matplotlib.use("TkAgg")
        except Exception:
            pass
        import matplotlib.pyplot as plt
        import matplotlib.patheffects as pe
        from matplotlib.widgets import Button
        from matplotlib.patches import Rectangle

        X_MIN, X_MAX = -10.0, 10.0
        N_PTS = 4000

        def build_curve(xmin, xmax):
            xs = np.linspace(xmin, xmax, N_PTS)
            ys = []
            for xv in xs:
                try: ys.append(safe_eval(float(xv), eq))
                except: ys.append(float("nan"))
            return xs, np.array(ys)

        x_vals, y_vals = build_curve(X_MIN, X_MAX)
        fig = plt.figure(figsize=(10, 7), facecolor="#f5f7fa")
        ax  = fig.add_axes([0.08, 0.12, 0.88, 0.80])
        ax.set_facecolor("#ffffff")
        curve_line, = ax.plot(x_vals, y_vals, color="#3498db", linewidth=2.2,
                              label=f"f(x) = {eq}", zorder=2)
        ax.axhline(0, color="#7f8c8d", linewidth=0.7, linestyle="--", zorder=1)
        ax.axvline(0, color="#7f8c8d", linewidth=0.7, linestyle="--", zorder=1)

        dot_xy, dot_labels = [], []
        if iter_points:
            n = len(iter_points)
            cmap = plt.cm.Blues
            for idx, (it_num, xp) in enumerate(iter_points):
                try: yp = safe_eval(float(xp), eq)
                except: continue
                color = cmap(0.4 + 0.6 * idx / max(n - 1, 1))
                ax.scatter(xp, yp, color=color, s=90, zorder=5,
                           edgecolors="#2c3e50", linewidths=0.8, picker=5)
                dot_xy.append((xp, yp)); dot_labels.append(str(it_num))
                txt = ax.text(xp, yp, f" {it_num}", color="#2c3e50", fontsize=8,
                              fontweight="bold", va="bottom", zorder=6, fontfamily="Consolas")
                txt.set_path_effects([pe.withStroke(linewidth=2, foreground="#ffffff")])
                ax.plot([xp, xp], [0, yp], color="#bdc3c7", linewidth=0.4,
                        linestyle=":", alpha=0.6, zorder=1)

        title = f"f(x) = {eq}" + (f"  [{method_name}]" if method_name else "")
        ax.set_title(title, color="#2c3e50", fontsize=12, pad=10)
        ax.set_xlabel("x", color="#2c3e50", fontsize=11)
        ax.set_ylabel("f(x)", color="#2c3e50", fontsize=11)
        ax.tick_params(colors="#2c3e50", labelsize=9)
        for sp in ax.spines.values(): sp.set_color("#bdc3c7")
        ax.grid(True, color="#ecf0f1", linewidth=0.5, alpha=0.9)
        ax.legend(facecolor="#ffffff", edgecolor="#bdc3c7", labelcolor="#2c3e50", fontsize=9)

        tooltip = ax.annotate("", xy=(0,0), xytext=(14,14), textcoords="offset points",
            bbox=dict(boxstyle="round,pad=0.4", fc="#ffffff", ec="#3498db", lw=1.2),
            arrowprops=dict(arrowstyle="->", color="#3498db"),
            fontfamily="Consolas", fontsize=9, color="#2c3e50", zorder=10, visible=False)

        def on_motion(event):
            if event.inaxes != ax:
                tooltip.set_visible(False); fig.canvas.draw_idle(); return
            cx = event.xdata
            try:
                cy = safe_eval(float(cx), eq)
                tooltip.set_text(f"x = {cx:.5f}\nf(x) = {cy:.5f}")
                tooltip.xy = (cx, cy); tooltip.set_visible(True)
            except: tooltip.set_visible(False)
            hit = (ax.get_xlim()[1] - ax.get_xlim()[0]) * 0.015
            for (xp, yp), lbl in zip(dot_xy, dot_labels):
                if abs(cx - xp) < hit:
                    try: fyp = safe_eval(float(xp), eq)
                    except: fyp = yp
                    tooltip.set_text(f"Iteration {lbl}\nx = {xp:.6f}\nf(x) = {fyp:.6f}")
                    tooltip.xy = (xp, fyp); tooltip.set_visible(True); break
            fig.canvas.draw_idle()

        ZOOM = 1.25
        def on_scroll(event):
            if event.inaxes != ax: return
            xd, yd = event.xdata, event.ydata
            f = 1/ZOOM if event.button == "up" else ZOOM
            ax.set_xlim([xd+(x-xd)*f for x in ax.get_xlim()])
            ax.set_ylim([yd+(y-yd)*f for y in ax.get_ylim()])
            redraw_curve(); fig.canvas.draw_idle()

        _rs=[None]; _rp=[None]; _pan=[False]; _ps=[None]
        def on_press(ev):
            if ev.inaxes != ax: return
            if ev.button == 1: _pan[0]=True; _ps[0]=(ev.xdata,ev.ydata,ax.get_xlim(),ax.get_ylim())
            elif ev.button == 3:
                _rs[0]=(ev.xdata,ev.ydata)
                r=Rectangle((ev.xdata,ev.ydata),0,0,lw=1.2,ec="#3498db",fc="#3498db",alpha=0.15,zorder=20)
                ax.add_patch(r); _rp[0]=r
        def on_release(ev):
            if ev.button==1: _pan[0]=False; _ps[0]=None
            elif ev.button==3 and _rs[0]:
                if _rp[0]: _rp[0].remove(); _rp[0]=None
                x0,y0=_rs[0]; x1,y1=ev.xdata or x0,ev.ydata or y0; _rs[0]=None
                if abs(x1-x0)>1e-9 and abs(y1-y0)>1e-9:
                    ax.set_xlim(sorted([x0,x1])); ax.set_ylim(sorted([y0,y1])); redraw_curve()
                fig.canvas.draw_idle()
        def on_drag(ev):
            if ev.inaxes != ax: return
            if _pan[0] and _ps[0]:
                x0,y0,xl,yl=_ps[0]
                dx=ev.xdata-x0 if ev.xdata else 0; dy=ev.ydata-y0 if ev.ydata else 0
                ax.set_xlim([xl[0]-dx,xl[1]-dx]); ax.set_ylim([yl[0]-dy,yl[1]-dy])
                redraw_curve(); fig.canvas.draw_idle()
            elif _rp[0] and _rs[0]:
                x0,y0=_rs[0]; x1=ev.xdata or x0; y1=ev.ydata or y0
                _rp[0].set_width(x1-x0); _rp[0].set_height(y1-y0); fig.canvas.draw_idle()

        def redraw_curve():
            xl,xr=ax.get_xlim(); m=(xr-xl)*0.05
            xs,ys=build_curve(xl-m,xr+m); curve_line.set_data(xs,ys)

        fig.canvas.mpl_connect("motion_notify_event", on_motion)
        fig.canvas.mpl_connect("scroll_event", on_scroll)
        fig.canvas.mpl_connect("button_press_event",   on_press)
        fig.canvas.mpl_connect("button_release_event", on_release)
        fig.canvas.mpl_connect("motion_notify_event",  on_drag)

        btn_ax = fig.add_axes([0.40,0.02,0.20,0.045])
        btn_ax.set_facecolor("#ecf0f1")
        rb = Button(btn_ax,"Reset View",color="#ecf0f1",hovercolor="#d5dbdb")
        rb.label.set_color("#2c3e50"); rb.label.set_fontfamily("Consolas"); rb.label.set_fontsize(10)
        def on_reset(ev):
            ax.set_xlim(X_MIN,X_MAX); xs,ys=build_curve(X_MIN,X_MAX); curve_line.set_data(xs,ys)
            fin=ys[np.isfinite(ys)]
            if len(fin):
                m=(fin.max()-fin.min())*0.1 or 1; ax.set_ylim(fin.min()-m,fin.max()+m)
            fig.canvas.draw_idle()
        rb.on_clicked(on_reset)

        sa=fig.add_axes([0.08,0.005,0.88,0.025]); sa.axis("off")
        sa.text(0.5,0.5,"Scroll to zoom  |  Left-drag to pan  |  Right-drag to box-zoom  |  Hover for coords",
                ha="center",va="center",color="#95a5a6",fontfamily="Consolas",fontsize=8,transform=sa.transAxes)

        fin=y_vals[np.isfinite(y_vals)]
        if len(fin):
            m=(fin.max()-fin.min())*0.12 or 1; ax.set_ylim(fin.min()-m,fin.max()+m)
        plt.show()
    except ImportError:
        messagebox.showinfo("Plot","Install matplotlib:\n  pip install matplotlib")


